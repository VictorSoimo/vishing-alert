<!-- Assuming your existing layout is ConstraintLayout or similar -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:gravity="center_horizontal"
    tools:context=".MainActivity">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Vishing Guard Service Control"
        android:textSize="24sp"
        android:layout_marginBottom="32dp"/>

    <EditText
        android:id="@+id/recipientPhoneNumber"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Enter Scam Recipient Number (e.g., +15551234)"
        android:inputType="phone"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/startCallButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="START MONITORED CALL"
        android:backgroundTint="#FF6F00"
        android:textColor="@android:color/white"
        android:padding="16dp"
        android:textSize="18sp"
        android:elevation="4dp"/>

    <Button
        android:id="@+id/stopServiceButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STOP SERVICE"
        android:layout_marginTop="24dp"
        android:backgroundTint="#D32F2F"
        android:textColor="@android:color/white"
        android:padding="12dp"/>

</LinearLayout>
